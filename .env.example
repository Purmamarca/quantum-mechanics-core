# Environment Variables Template
# Copy this file to .env and fill in your actual values
# .env is gitignored and will never be committed

# API Keys (example - not real)
# API_KEY=your_api_key_here
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Database Configuration (example - not real)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=gauss_clean_energy

# Application Settings
# NODE_ENV=development
# PORT=3000
# DEBUG=true

# Third-party Services (example - not real)
# STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Authentication (example - not real)
# JWT_SECRET=your_jwt_secret_here
# SESSION_SECRET=your_session_secret_here

# Note: This is a TEMPLATE file
# Actual values should be in .env (which is gitignored)
# Never commit real API keys or secrets to version control!
